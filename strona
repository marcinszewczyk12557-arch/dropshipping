*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial, Helvetica, sans-serif;
}

body{
background:#f5f7fa;
color:#333;
}

header{
background:linear-gradient(135deg,#0a3d62,#1e90ff);
color:white;
text-align:center;
padding:60px 20px;
}

header img{
width:180px;
margin-bottom:20px;
}

header h1{
font-size:40px;
letter-spacing:2px;
}

header p{
margin-top:10px;
font-size:18px;
opacity:0.9;
}

.container{
max-width:1100px;
margin:auto;
padding:40px 20px;
}

.section{
margin-bottom:50px;
}

.section h2{
font-size:30px;
margin-bottom:20px;
color:#0a3d62;
}

.card{
background:white;
padding:30px;
border-radius:10px;
box-shadow:0 6px 20px rgba(0,0,0,0.08);
line-height:1.7;
}

ul{
margin-top:10px;
padding-left:20px;
}

li{
margin-bottom:12px;
}

.email{
